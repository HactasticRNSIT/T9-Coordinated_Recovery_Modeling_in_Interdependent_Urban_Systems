# UrbanSync AI — Backend Environment Variables
# Copy this file to .env and fill in your values

# Application
ENVIRONMENT=development
DEBUG=true

# Database (PostgreSQL + PostGIS)
DATABASE_URL=postgresql://urbansync:urbansync_dev_password@localhost:5432/urbansync

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-this-to-a-random-256-bit-key-in-production

# ML Models
ML_MODELS_PATH=./ml_pipeline/artifacts
GNN_MODEL_VERSION=gnn-v1.0
LSTM_MODEL_VERSION=lstm-v1.0
XGB_MODEL_VERSION=xgb-v1.0

# Simulation
DEFAULT_MONTE_CARLO_RUNS=100
MAX_MONTE_CARLO_RUNS=500
